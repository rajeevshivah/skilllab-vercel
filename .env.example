# These go in Vercel → Project Settings → Environment Variables

# MongoDB Atlas connection string (from Step 1 in DEPLOY.md)
MONGODB_URI=mongodb+srv://skilllab_user:yourpassword@cluster0.xxxxx.mongodb.net/skilllab

# Any long random secret string for signing JWT tokens
JWT_SECRET=sheat_skilllab_secret_change_this_2026

# Your Vercel deployment URL (update after first deploy)
FRONTEND_URL=https://skilllab.sheat.ac.in

# For local dev only — Vite needs this to proxy API calls
# VITE_API_URL=/api
